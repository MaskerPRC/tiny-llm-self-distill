# 服务端口
PORT=3000

# ===== Gemini 3.1 Pro (处理用户请求) =====
GEMINI_API_BASE=https://openrouter.ai/api/v1
GEMINI_API_KEY=sk-or-v1-xxx
GEMINI_MODEL=google/gemini-3.1-pro-preview

# ===== Gemini 2.5 Flash (训练数据生成 + 标注) =====
DATAGEN_API_BASE=https://openrouter.ai/api/v1
DATAGEN_API_KEY=sk-or-v1-xxx
DATAGEN_MODEL=google/gemini-2.5-flash-lite
# 数据生成并发数（同时生成多少条数据，每条需2次API调用）
DATAGEN_CONCURRENCY=20

# ===== Claude Opus 4.6 (代码迭代 + 流程修改) =====
CLAUDE_API_BASE=https://openrouter.ai/api/v1
CLAUDE_API_KEY=sk-or-v1-xxx
CLAUDE_MODEL=anthropic/claude-opus-4.6

# ===== Python路径 =====
PYTHON_PATH=python

# ===== 自进化配置 =====
# 触发进化的最少请求数
EVOLVE_MIN_REQUESTS=50
# 任务类型占比阈值 (超过此比例触发蒸馏)
EVOLVE_PATTERN_THRESHOLD=0.3
# 小模型置信度阈值 (低于此值回退到LLM)
PREDICT_CONFIDENCE_THRESHOLD=0.8
# 训练数据生成数量
TRAIN_DATA_COUNT=5000
# 训练 epochs
TRAIN_EPOCHS=5
# 验证集比例
TRAIN_VAL_SPLIT=0.2

# ===== GPT-5.4 (进化意图分析) =====
INTENT_API_BASE=https://openrouter.ai/api/v1
INTENT_API_KEY=sk-or-v1-xxx
INTENT_MODEL=openai/gpt-5.4

# ===== GPT-5.4 (模型架构选型决策) =====
SELECTOR_API_BASE=https://openrouter.ai/api/v1
SELECTOR_API_KEY=sk-or-v1-xxx
SELECTOR_MODEL=openai/gpt-5.4

# 可用候选架构（逗号分隔，会根据任务复杂度自动选最小够用的）
MODEL_CANDIDATES=fasttext,tinybert,minilm,distilbert
